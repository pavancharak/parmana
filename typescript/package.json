{
  "name": "parmana",
  "version": "1.0.0",
  "description": "Official Parmana TypeScript SDK",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "keywords": [
    "parmana",
    "ai",
    "governance",
    "authorization",
    "verification",
    "execution",
    "trust",
    "agentic-ai",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/parmana-ai/parmana.git"
  },
  "bugs": {
    "url": "https://github.com/parmana-ai/parmana/issues"
  },
  "homepage": "https://parmana.ai",
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^4.1.9",
    "@types/node": "^24.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}