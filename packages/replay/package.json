{
    "name": "@parmana/replay",
    "version": "0.1.0",
    "description": "Parmana Replay Engine - Deterministic execution reconstruction system",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
