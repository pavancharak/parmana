{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",

    "composite": true,
    "declaration": true,
    "declarationMap": true,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"]
}