{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": ["src/**/*.ts"],

  "exclude": ["dist", "test", "tests", "**/*.test.ts", "**/*.spec.ts"]
}
