  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.parmana.ai/common/receipt.schema.json",
  "title": "Receipt",
  "description": "Canonical Execution Trust Receipt.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receiptId",
    "executionTrustRecordId",
    "businessTransactionId",
    "executionId",
    "issuedAt",
    "receiptVersion",
    "executionTrustRecordHash",
    "signature"
  ],
  "properties": {
    "receiptId": {
      "type": "string",
      "description": "Unique Receipt identifier."
    },
    "executionTrustRecordId": {
      "type": "string",
      "description": "Execution Trust Record identifier."
    },
    "businessTransactionId": {
      "type": "string",
      "description": "Business Transaction identifier."
    },
    "executionId": {
      "type": "string",
      "description": "Execution identifier."
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the Receipt was issued."
    },
    "receiptVersion": {
      "type": "string",
      "description": "Receipt specification version."
    },
    "executionTrustRecordHash": {
      "type": "string",
      "description": "Canonical hash of the Execution Trust Record."
    },
    "signature": {
      "type": "string",
      "description": "Digital signature over the Receipt."
    },
    "keyId": {
      "type": "string",
      "description": "Identifier of the signing key used to generate the Receipt."
    },
    "algorithm": {
      "type": "string",
      "description": "Digital signature algorithm.",
      "examples": [
        "Ed25519"
      ]
    }
  },
  "examples": [
    {
