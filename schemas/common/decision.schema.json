    "reason": {
      "type": "string",
      "description": "Human-readable explanation of the decision."
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when policy evaluation completed."
    },
    "policy": {
      "$ref": "./policy.schema.json"
    }
  },
  "examples": [
    {
      "decisionId": "DEC-000001",
